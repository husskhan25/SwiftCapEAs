{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard/index.html" },
    { "source": "/dashboard/licenses", "destination": "/dashboard/licenses.html" },
    { "source": "/dashboard/profile", "destination": "/dashboard/profile.html" },
    { "source": "/dashboard/set-password", "destination": "/dashboard/set-password.html" },
    { "source": "/dashboard/forgot-password", "destination": "/dashboard/forgot-password.html" },
    { "source": "/dashboard/reset-password", "destination": "/dashboard/reset-password.html" },
    { "source": "/sc-admin-panel", "destination": "/sc-admin-panel/index.html" },
    { "source": "/sc-admin-panel/dashboard", "destination": "/sc-admin-panel/dashboard.html" },
    { "source": "/sc-admin-panel/products", "destination": "/sc-admin-panel/products.html" },
    { "source": "/sc-admin-panel/users", "destination": "/sc-admin-panel/users.html" },
    { "source": "/sc-admin-panel/settings", "destination": "/sc-admin-panel/settings.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    },
    {
      "source": "/sc-admin-panel/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
